{
  "name": "@lydia/openclaw-plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/openclaw-entry.js"
    ]
  },
  "dependencies": {
    "@lydia/core": "workspace:*"
